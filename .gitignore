# === JukuMate 公開リポ用 .gitignore ===
# 公開: site/, worker/, README.md, .gitignore
# 非公開: 内部設計資料・コピー検討・モックアップ・社内ドキュメント全般

# --- 内部設計資料（社内議論ログ含む、公開不可） ---
/docs/
/copy/
/spec.html
/design.md
/worktree-temp/

# --- モックアップ・素材（root レベルの内部用） ---
/mockups/
/assets/

# --- site 直下の内部運用ミラー・ローカル開発支援 ---
/site/gas/
/site/scripts/
/site/tests/
/site/playwright.config.ts

# --- site 直下のローカル成果物・スクリーンショット ---
/site/lighthouse-*.json
/site/phase*-*.png
/site/phase*-*.html
/site/.screenshots/
/site/screenshots/
/site/test-results/
/site/playwright-report/
/site/playwright/.cache/

# --- ビルド出力（各サブパス明示） ---
/site/dist/
/site/.astro/
/site/.vercel/
/worker/dist/
/worker/.wrangler/

# --- 環境変数（各サブパス明示） ---
/site/.env
/site/.env.local
/site/.env.production
/site/.env.development
/worker/.dev.vars

# --- node_modules（再帰マッチ OK、対象が node_modules 限定なので安全） ---
**/node_modules/

# --- 過去ファイル・バックアップ ---
*.bak
/docs.bak/

# --- OS / IDE ---
.DS_Store
Thumbs.db
desktop.ini
.vscode/
.idea/
*.swp
*.swo

# --- ログ（再帰 OK、log 拡張子のみ） ---
**/*-debug.log*
**/npm-debug.log*
**/yarn-debug.log*
**/pnpm-debug.log*
