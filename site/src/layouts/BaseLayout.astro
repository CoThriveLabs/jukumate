---
import '../styles/global.css';
import SeoHead from '../components/common/SeoHead.astro';
import Header from '../components/common/Header.astro';
import Footer from '../components/common/Footer.astro';
import type { FaqItem } from '../lib/jsonld';

export interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  /** FAQPage JSON-LD を出力する場合のみ渡す（トップページのみ） */
  faqs?: FaqItem[];
}

const { title, description, canonical, ogImage, faqs } = Astro.props;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    {/* Noto Serif JP / Noto Sans JP（既存） + DM Sans（Phase 3a v2 追加） */}
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;600;700;800&family=Noto+Sans+JP:wght@400;500;700&family=Noto+Serif+JP:wght@500;700&display=swap"
      onload="this.onload=null;this.rel='stylesheet'"
    />
    <noscript>
      <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;600;700;800&family=Noto+Sans+JP:wght@400;500;700&family=Noto+Serif+JP:wght@500;700&display=swap" />
    </noscript>

    <SeoHead
      title={title}
      description={description}
      canonical={canonical}
      ogImage={ogImage}
      faqs={faqs}
    />
  </head>
  <body class="bg-cream text-ink font-sans antialiased">
    <Header />
    <slot />
    <Footer />

    {/* Phase 3a v2: IntersectionObserver 共通ユーティリティ + カウントアップ */}
    {/* Phase 4: 予約フォーム（flatpickr + GAS fetch + モーダル制御） */}
    <script>
      import '../scripts/useFadeInUp';
      import '../scripts/useCountUp';
      import '../scripts/useContactForm';
    </script>
  </body>
</html>
