---
/**
 * ParentReportDemo — 保護者レポート下書き AI（1 ターン完結）
 *
 * - 講師が「今週の生徒の様子」を 10-800 字で入力 → 1 通の保護者向け週次レポート下書きを返す
 * - WORKER_URL 必須（未設定時はエラー表示）
 * - 統一エラー文（UNIFIED_ERROR_MESSAGE）採用
 * - a11y: role=status, aria-live=polite で生成完了を通知
 * - iOS Safari 自動ズーム防止のため textarea は text-[16px] md:text-[15px]
 */
---

<article
  class="bg-white rounded-[16px] shadow-panel border border-line/60 p-6 md:p-10 js-fadeInUp relative overflow-hidden"
  aria-labelledby="parent-report-heading"
>
  {/* T-20 装飾: 折り紙モチーフをうっすら背景に */}
  <span
    aria-hidden="true"
    class="absolute top-4 right-4 w-24 h-24 opacity-[0.04] pointer-events-none text-sage"
  >
    <img src="/motifs/folded-paper.svg" alt="" class="w-full h-full" />
  </span>

  <header class="flex items-start gap-4 relative">
    <span
      aria-hidden="true"
      class="inline-flex shrink-0 items-center justify-center w-12 h-12 rounded-full"
      style="background-color: color-mix(in srgb, var(--color-sage) 10%, transparent); color: var(--color-sage);"
    >
      <img src="/motifs/feather.svg" alt="" class="w-6 h-6" />
    </span>
    <div>
      <p class="font-display text-[11px] font-bold tracking-[0.33em] text-terracotta-cta">
        保護者レポート下書き AI
      </p>
      <h3
        id="parent-report-heading"
        class="font-serif font-bold text-[20px] md:text-[24px] text-ink mt-1"
      >
        <span class="whitespace-nowrap">今週の様子を、</span><span class="whitespace-nowrap">保護者向けの 1 通に。</span>
      </h3>
      <p class="text-[14px] md:text-[15px] text-ink-soft mt-2 leading-[1.85]">
        生徒の 1 週間の様子・データを入れていただくと、保護者向けの週次レポート下書きを AI が 1 通生成します。
        <span class="block mt-1 text-[12px]">10〜800 文字 / 生成 1 回完結</span>
      </p>
    </div>
  </header>

  <form data-pr-form class="mt-8 flex flex-col gap-3 relative">
    <label for="pr-input" class="sr-only">今週の生徒の様子を入力</label>
    <textarea
      id="pr-input"
      data-pr-input
      maxlength="800"
      rows="6"
      placeholder="例: 中学2年生・男子。数学の小テスト 80 点（先週 65 点）、英語の宿題提出率 100%、授業中の発言が増えた。来週は期末テスト前の集中演習。
※ 生徒・保護者の実名や個人情報は入れないでください"
      class="w-full bg-paper border border-line rounded-[8px] p-4 text-[16px] md:text-[15px] leading-[1.85] text-ink resize-none focus:outline-none focus:ring-2 focus:ring-sage placeholder:text-ink-soft/70"
    ></textarea>
    <div class="flex items-center justify-between gap-3">
      <span data-pr-counter class="text-[12px] text-ink-soft">0 / 800 文字</span>
      <button
        data-pr-submit
        type="submit"
        class="inline-flex items-center gap-2 bg-ink hover:bg-ink-darker text-cream disabled:bg-line disabled:text-ink-soft disabled:cursor-not-allowed text-[14px] font-bold tracking-[0.04em] px-6 py-3 rounded-[4px] transition-colors"
      >
        下書きを生成
      </button>
    </div>
  </form>

  {/* 生成中ローディング */}
  <div
    data-pr-loading
    hidden
    class="mt-6 flex items-center gap-3 py-8 text-ink-soft justify-center bg-cream-deep/60 rounded-[12px]"
  >
    <span aria-hidden="true" class="ai-loading flex gap-1.5">
      <span class="w-2 h-2 rounded-full bg-sage"></span>
      <span class="w-2 h-2 rounded-full bg-sage" style="animation-delay: 0.2s;"></span>
      <span class="w-2 h-2 rounded-full bg-sage" style="animation-delay: 0.4s;"></span>
    </span>
    <span class="text-[13px]">レポートを書いています...</span>
  </div>

  {/* 結果カード */}
  <output
    data-pr-result
    for="pr-input"
    hidden
    role="status"
    aria-live="polite"
    class="mt-6 block bg-paper rounded-[12px] p-5 md:p-6 border border-line/60"
  >
    <p class="font-display text-[11px] font-bold tracking-[0.25em] text-sage-dark">DRAFT</p>
    <pre
      data-pr-text
      class="mt-3 font-serif text-[15px] md:text-[16px] leading-[1.95] text-ink whitespace-pre-wrap"
    ></pre>
  </output>

  {/* エラー */}
  <div
    data-pr-error
    hidden
    role="alert"
    class="mt-4 bg-terracotta-pale border border-terracotta-soft rounded-[8px] p-4 text-[14px] text-terracotta-cta-dark leading-[1.85]"
  >
  </div>

  {/* CTA */}
  <div class="mt-6 flex flex-wrap gap-3 items-center">
    <button
      type="button"
      data-form-trigger
      class="inline-flex items-center gap-2 bg-terracotta-cta hover:bg-terracotta-cta-dark text-cream text-[13px] font-bold tracking-[0.04em] px-6 py-3 rounded-[4px] transition-colors cursor-pointer border-0"
      aria-label="実際の運用について 30 分で相談する（予約フォームを開く）"
    >
      実際の運用について 30 分で相談する
    </button>
    <span class="text-[12px] text-ink-soft">※ 本デモは下書き提案で、実運用ではテンプレ整備が別途必要です</span>
  </div>
</article>

<script>
  import '../../scripts/useParentReportDemo';
</script>

<style>
  /* useDiagnoseChat と同じ 3 ドットローディング演出（既存 .ai-loading を再利用）*/
  .ai-loading span {
    animation: ai-loading-bounce 1.2s ease-in-out infinite;
  }
  @keyframes ai-loading-bounce {
    0%, 80%, 100% { transform: translateY(0); opacity: 0.4; }
    40% { transform: translateY(-4px); opacity: 1; }
  }
  @media (prefers-reduced-motion: reduce) {
    .ai-loading span { animation: none; }
  }
</style>
