---
/**
 * Beta — セクション 6: 信頼性 = ベータ募集（一緒に作る軸）
 *
 * 構造:
 *   - <a id="final-cta">: 最終 CTA スクロールターゲット
 *   - メインコピーカード（H3 + リード）
 *   - sprout SVG 装飾
 *   - ラスト後押しゾーン: 募集帯 + 後押し 1 行 + 2 ボタン CTA + 注釈
 *
 * 主 CTA は <button data-form-trigger> として、クリックで ContactFormModal を起動する。
 * モーダル内: flatpickr（multiple, 上限 3, 平日のみ）+ フォーム項目 + ハニーポット + 同意チェック。
 * 送信先: 環境変数 PUBLIC_GAS_URL → GAS Web App doPost → Sheets 追記 + 通知メール + 業種別自動返信メール。
 */
import ContactFormModal from '../forms/ContactFormModal.astro';
---

{/* 最終 CTA スクロールターゲット（Header 固定 64px オフセット相殺込み） */}
<a
  id="final-cta"
  class="block scroll-mt-20 md:scroll-mt-24"
  aria-hidden="true"
  tabindex="-1"
></a>

<section
  id="beta"
  aria-labelledby="beta-heading"
  class="bg-paper relative overflow-hidden py-24 md:py-32"
>
  {/* 右上に sprout SVG 装飾（一緒に作る軸、双葉の sage カラー） */}
  <img
    src="/motifs/sprout.svg"
    alt=""
    aria-hidden="true"
    class="hidden md:block absolute -top-4 right-12 w-40 lg:w-56 opacity-[0.08] rotate-[12deg] pointer-events-none"
    style="color: var(--color-sage-dark);"
  />

  <div class="relative mx-auto max-w-5xl px-6 md:px-12">
    {/* メインコピーカード（H3 + サブコピー）— 付箋デザイン */}
    <div
      class="sticky-card relative mt-14 md:mt-16 bg-[#FDFCFA] rounded-[16px] p-7 md:p-10 border border-line/50 js-fadeInUp"
      data-stagger="0"
    >
      <h3
        id="beta-heading"
        class="font-serif font-bold text-[20px] md:text-[24px] lg:text-[32px] xl:text-[36px] text-sage-dark leading-[1.5] text-center"
      >
        <span class="whitespace-nowrap">一緒に作ってくださる</span>
        <span class="whitespace-nowrap">先生方を、</span><span class="whitespace-nowrap">募集しています。</span>
      </h3>
      <p
        class="mt-5 text-[15px] md:text-[16px] leading-[1.95] text-ink-soft text-center max-w-[680px] mx-auto"
      >
        <span class="whitespace-nowrap">ご参加いただいた先生方のお声を</span><span class="whitespace-nowrap">一つ一つ</span><span class="whitespace-nowrap">受けとめながら</span><span class="whitespace-nowrap">JukuMateを</span><span class="whitespace-nowrap">作って</span><span class="whitespace-nowrap">います。</span>
        <span class="whitespace-nowrap">初期セットアップから初回データ移行、</span><span class="whitespace-nowrap">操作レクチャーまで、</span><span class="whitespace-nowrap"><strong class="text-ink">専任スタッフ</strong>が</span><span class="whitespace-nowrap">伴走</span><span class="whitespace-nowrap">します。</span>
      </p>
    </div>

    {/* ラスト後押しゾーン */}
    <div class="mt-14 md:mt-16 text-center js-fadeInUp" data-stagger="2">
      {/* ラスト後押し 1 行 */}
      <p class="font-serif text-[16px] md:text-[18px] leading-[1.9] text-ink max-w-[640px] mx-auto">
        「教える」だけに集中できる毎日を、<br class="md:hidden" />
        一緒に作りはじめませんか。
      </p>

      {/* 2 ボタン CTA */}
      <div class="mt-8 flex flex-col md:flex-row items-center justify-center gap-4">
        <button
          type="button"
          data-form-trigger
          class="inline-flex items-center justify-center gap-2 bg-terracotta-cta hover:bg-terracotta-cta-dark text-cream text-[14px] md:text-[15px] font-bold tracking-[0.04em] px-7 py-3.5 rounded-[4px] transition-colors w-full md:w-auto cursor-pointer border-0"
        >
          30分・無料相談を予約する
        </button>
        <a
          href="#"
          class="inline-flex items-center justify-center gap-2 bg-white hover:bg-cream-deep text-ink border border-line text-[14px] md:text-[15px] font-bold tracking-[0.04em] px-7 py-3.5 rounded-[4px] transition-colors w-full md:w-auto"
        >
          資料をダウンロード
        </a>
      </div>

      <p class="mt-3 text-[13px] md:text-[14px] text-ink-soft">いずれも無料です。無理な勧誘はいたしません。</p>
    </div>
  </div>

  {/* 予約フォームモーダル本体（fixed positioning） */}
  <ContactFormModal />
</section>

<style>
  /* 付箋カード — 上部中央に水平テープ */
  .sticky-card {
    box-shadow:
      0 4px 16px rgba(0, 0, 0, 0.06),
      0 2px 4px rgba(0, 0, 0, 0.04),
      2px 6px 10px rgba(0, 0, 0, 0.03);
  }
  .sticky-card::before {
    content: '';
    position: absolute;
    top: -14px;
    left: 50%;
    transform: translateX(-50%);
    width: 100px;
    height: 28px;
    background: rgba(180, 130, 100, 0.5);
    border: 1px solid rgba(0, 0, 0, 0.06);
    border-radius: 2px;
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.05);
    pointer-events: none;
  }
  @media (min-width: 768px) {
    .sticky-card::before {
      width: 120px;
      height: 32px;
      top: -16px;
    }
  }
</style>
