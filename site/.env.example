# JukuMate LP — ローカル / テスト用 環境変数
#
# - 本番運用時は Cloudflare Pages の Environment Variables にも同名で登録すること。
# - ローカル開発時は本ファイルを `.env.local` にコピーして使う。`.env.local` は gitignore 対象。
# - `PUBLIC_` プレフィックスはクライアントサイドにバンドルされる前提（Astro 仕様）。

# PUBLIC_GAS_URL: GAS Web App URL
#   コード修正のたびに GAS Web UI で「新しいデプロイ」を作成し、
#   発行された新 URL に書き換える必要があります（手動運用）。
PUBLIC_GAS_URL=https://script.google.com/macros/s/REPLACE_WITH_DEPLOYMENT_ID/exec

# PUBLIC_TURNSTILE_SITE_KEY: Cloudflare Turnstile Site Key
#   - Cloudflare ダッシュボード → Turnstile → サイト追加 で「サイトキー(Public)」を発行して下記に設定。
#   - 本番では Cloudflare Pages の Environment Variables にも同名で登録すること（クライアントサイドにバンドルされる前提）。
#   - シークレットキー(Secret)は GAS スクリプトプロパティ `TURNSTILE_SECRET_KEY` に別途登録（リポジトリには絶対に置かない）。
#   - ローカル開発時は MOCKED_FOR_LOCAL_TESTING を指定すると公式 JS をロードせずダミートークンが流れ、UI 動線確認が可能。
PUBLIC_TURNSTILE_SITE_KEY=REPLACE_WITH_TURNSTILE_SITE_KEY
